{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "Renode Debug",
      "type": "cortex-debug",
      "request": "launch",

      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/output/stm32f411.elf",

      "servertype": "external",
      "gdbTarget": "localhost:3333",
      "gdbPath": "/usr/bin/gdb-multiarch",

      "device": "STM32F411",
      "interface": "swd",

      "runToEntryPoint": "main",

      // "svdFile": "/home/satish/Documents/MCU/STM32/hal_prj/external/svd/STM32F411.svd",
      "svdFile": "${workspaceRoot}/external/svd/STM32F411.svd",
      
      "preLaunchCommands": [
        "monitor reset",
        "monitor halt"
      ],

      "postRestartCommands": [
        "monitor reset",
        "monitor halt"
      ],

      "showDevDebugOutput": "raw"
    },

    {
      "name": "ST-Link Hardware",
      "type": "cortex-debug",
      "request": "launch",

      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/output/stm32f411.elf",

      "servertype": "openocd",

      "toolchainPrefix": "arm-none-eabi",
      "gdbPath": "/usr/bin/gdb-multiarch",
      "objdumpPath": "/usr/bin/arm-none-eabi-objdump",

      "device": "STM32F411",
      "interface": "swd",

      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f4x.cfg"
      ],

      "searchDir": [
        "/usr/share/openocd/scripts"
      ],

      "runToEntryPoint": "main",

      "svdFile": "${workspaceFolder}external/svd/STM32F411.svd",

      "openOCDLaunchCommands": [
        "adapter speed 1000"
      ],

      "postLaunchCommands": [
        "monitor reset halt"
      ],

      "showDevDebugOutput": "raw"
    }

  ]
}